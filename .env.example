# ── z8run environment ──────────────────────────────────────
# Copy to .env and adjust for your deployment

# Database (local dev uses SQLite by default)
Z8_DB_URL=postgres://z8run:z8run_secret@localhost:5432/z8run
Z8_PORT=7700
Z8_LOG_LEVEL=info
Z8_BIND=0.0.0.0
Z8_DATA_DIR=./data

# ── Docker deployment ─────────────────────────────────────
# Password for the z8run PostgreSQL user
POSTGRES_PASSWORD=z8run_secret

# Encryption key for credential vault (MUST change in production!)
Z8_VAULT_SECRET=change-me-in-production

# Public port — use 80 behind Cloudflare, 8080 for local dev
Z8_PUBLIC_PORT=80
